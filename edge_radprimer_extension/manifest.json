{
  "manifest_version": 3,
  "name": "RadPrimer Prompt Runner",
  "version": "0.1.0",
  "description": "Extract RadPrimer articles and build Normal or Pathology prompt packages from Edge.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "clipboardWrite",
    "clipboardRead",
    "storage",
    "tabs",
    "windows",
    "debugger"
  ],
  "host_permissions": [
    "https://app.radprimer.com/*",
    "https://app.statdx.com/*",
    "https://radiopaedia.org/*",
    "https://www.radiopaedia.org/*",
    "https://prod-assets-static.radiopaedia.org/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://app.speechify.com/*",
    "https://imaios.com/*",
    "https://www.imaios.com/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "action": {
    "default_title": "RadPrimer Prompt Runner",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["imaios-page-context-probe.js"],
      "matches": ["https://imaios.com/*", "https://www.imaios.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://app.radprimer.com/*"],
      "js": ["radprimer-run-button.js", "radprimer-image-tools.js", "radprimer-speechify-remote.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://app.statdx.com/*"],
      "js": ["radprimer-run-button.js", "statdx-image-tools.js", "radprimer-speechify-remote.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://radiopaedia.org/*", "https://www.radiopaedia.org/*"],
      "js": ["radiopaedia-pacs-bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://radiopaedia.org/*", "https://www.radiopaedia.org/*"],
      "js": ["radiopaedia-pacs-viewer.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["chatgpt-draft-guard.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["chatgpt-paster.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://imaios.com/*", "https://www.imaios.com/*"],
      "js": ["imaios-live-drill-preload.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://imaios.com/*", "https://www.imaios.com/*"],
      "js": ["imaios-cine-tools.js"],
      "run_at": "document_idle"
    }
  ]
}
